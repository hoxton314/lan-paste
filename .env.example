# Server configuration
LAN_PASTE_PORT=3456
LAN_PASTE_HOST=0.0.0.0
LAN_PASTE_DB_PATH=./data/lan-paste.db
LAN_PASTE_STORAGE_DIR=./data/storage
LAN_PASTE_RETENTION_DAYS=7
LAN_PASTE_MAX_CLIP_SIZE_MB=10
LAN_PASTE_LOG_LEVEL=info

# Optional API key for auth (empty = no auth, Tailscale is primary security)
LAN_PASTE_API_KEY=

# Path to web UI dist (auto-detected in monorepo)
LAN_PASTE_WEB_DIR=
