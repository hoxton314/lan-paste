{
  "name": "lan-paste",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @lan-paste/server dev",
    "dev:web": "yarn workspace @lan-paste/web dev",
    "dev:all": "concurrently \"yarn dev\" \"yarn dev:web\"",
    "build": "yarn workspaces foreach -A run build",
    "build:server": "yarn workspace @lan-paste/server build",
    "build:web": "yarn workspace @lan-paste/web build",
    "build:cli": "yarn workspace @lan-paste/cli build",
    "typecheck": "yarn workspaces foreach -A run typecheck"
  }
}
